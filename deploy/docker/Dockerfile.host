# Managed "host" image: builds both Mayfly binaries (gnu target — no musl needed
# inside a Linux container) and runs sshd + mayfly-helper (root) + mayfly-agent
# (unprivileged) together, modelling a real deployment target.
#
# Build context: the mayfly-agent crate root.
#   docker build -f deploy/docker/Dockerfile.host -t mayfly-host .

FROM rust:1.74-bookworm AS builder
WORKDIR /src
COPY . .
RUN cargo build --release --bins

FROM debian:bookworm-slim
RUN apt-get update \
 && apt-get install -y --no-install-recommends openssh-server openssh-client procps util-linux \
 && rm -rf /var/lib/apt/lists/*

COPY --from=builder /src/target/release/mayfly-agent  /usr/local/bin/mayfly-agent
COPY --from=builder /src/target/release/mayfly-helper /usr/local/sbin/mayfly-helper
COPY deploy/docker/systemctl-shim.sh /usr/local/bin/systemctl-shim.sh
COPY deploy/docker/host-entrypoint.sh /usr/local/bin/host-entrypoint.sh
RUN chmod 0755 /usr/local/bin/systemctl-shim.sh /usr/local/bin/host-entrypoint.sh

EXPOSE 22
ENTRYPOINT ["/usr/local/bin/host-entrypoint.sh"]
